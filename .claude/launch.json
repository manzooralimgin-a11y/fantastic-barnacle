{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js · port 5000)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "NEXT_PUBLIC_API_URL=https://gestronomy-api-5atv.onrender.com/api npm run dev --prefix frontend"],
      "port": 5000
    },
    {
      "name": "Backend (FastAPI · port 8000)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    }
  ]
}
