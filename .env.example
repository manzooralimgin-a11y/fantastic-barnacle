# ===== DATABASE =====
# On Render, DATABASE_URL is auto-set from the managed PostgreSQL instance.
# Locally, set it directly:
DATABASE_URL=postgresql+asyncpg://gestronomy:gestronomy@localhost:5432/gestronomy
DATABASE_URL_SYNC=postgresql://gestronomy:gestronomy@localhost:5432/gestronomy

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0

# ===== AUTH =====
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SECURITY =====
# Max accepted request payload size in bytes.
MAX_REQUEST_SIZE_BYTES=1048576
# Rate limits per client IP within a 60-second window.
AUTH_RATE_LIMIT_PER_MINUTE=12
PUBLIC_RATE_LIMIT_PER_MINUTE=60

# ===== AI / LLM =====
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ===== INTEGRATIONS =====
# VoiceBooker webhook signature verification
VOICEBOOKER_SECRET=change-me-in-production
# Secret used by inbound hotel email processing webhook
EMAIL_INBOX_INGEST_SECRET=change-me-in-production
# Stripe webhook signing secret (required when Stripe is enabled)
STRIPE_WEBHOOK_SECRET=
# Resend email service (transactional emails, receipts)
RESEND_API_KEY=

# ===== APP =====
APP_NAME=Gestronomy
APP_ENV=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002
DAS_ELB_REST_API_URL=http://localhost:8000
DAS_ELB_REST_RESTAURANT_ID=
# In non-development environments, users must have restaurant_id set.
# APP_ENV=production enforces strict tenant context.

# ===== CELERY =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_LOG_LEVEL=INFO
CELERY_WORKER_CONCURRENCY=4

# ===== AWS STORAGE =====
AWS_REGION=eu-central-1
S3_BUCKET_NAME=
S3_DOCUMENTS_PREFIX=documents/
S3_UPLOADS_PREFIX=uploads/

# ===== CONTAINER STARTUP =====
# Keep migrations on for simple container bootstraps; disable only when running a
# dedicated migration job before the API starts.
RUN_MIGRATIONS=1
# Production should stay 0. Enable only for intentional bootstrap/local seed flows.
RUN_MASTER_SEED=0
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info
UVICORN_FORWARDED_ALLOW_IPS=*

# ===== FRONTEND (Next.js) =====
# Set on Render to the backend URL, e.g. https://gestronomy-api.onrender.com
# NEXT_PUBLIC_API_URL=https://gestronomy-api.onrender.com
