APP_NAME=Gestronomy
APP_ENV=production
DEBUG=false

BACKEND_URL=https://api.hotel.example
FRONTEND_URL=https://app.hotel.example
CORS_ORIGINS=https://app.hotel.example,https://hotel.example

DATABASE_URL=postgresql+asyncpg://USERNAME:PASSWORD@RDS_ENDPOINT:5432/gestronomy
DATABASE_URL_SYNC=postgresql://USERNAME:PASSWORD@RDS_ENDPOINT:5432/gestronomy

REDIS_URL=redis://ELASTICACHE_ENDPOINT:6379/0
CELERY_BROKER_URL=redis://ELASTICACHE_ENDPOINT:6379/1
CELERY_RESULT_BACKEND=redis://ELASTICACHE_ENDPOINT:6379/2
CELERY_LOG_LEVEL=INFO
CELERY_WORKER_CONCURRENCY=4

SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
VOICEBOOKER_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
EMAIL_INBOX_INGEST_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
ANTHROPIC_API_KEY=

# ===== IMAP INBOX POLLING =====
IMAP_HOST=imap.ionos.eu
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USERNAME=info@das-elb.de
IMAP_PASSWORD=REPLACE_WITH_IONOS_PASSWORD
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=120

AWS_REGION=eu-central-1
S3_BUCKET_NAME=hotel-prod-assets
S3_DOCUMENTS_PREFIX=documents/
S3_UPLOADS_PREFIX=uploads/

MAX_REQUEST_SIZE_BYTES=1048576
AUTH_RATE_LIMIT_PER_MINUTE=12
PUBLIC_RATE_LIMIT_PER_MINUTE=60
AVAILABILITY_RATE_LIMIT_PER_MINUTE=120
AVAILABILITY_RATE_LIMIT_BURST_PER_10_SECONDS=40
RESERVATION_WRITE_RATE_LIMIT_PER_MINUTE=30
RESERVATION_WRITE_RATE_LIMIT_BURST_PER_10_SECONDS=10

RUN_MIGRATIONS=0
RUN_MASTER_SEED=0
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info
UVICORN_FORWARDED_ALLOW_IPS=*
